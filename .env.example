# ============================================================
# PDF Agent Toolbox — Environment Variables
# Copy to .env and adjust values. All use the PDF_AGENT_ prefix.
# ============================================================

# ── App ──
PDF_AGENT_DEBUG=false

# ── Database (async — FastAPI / SQLAlchemy) ──
PDF_AGENT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pdf_agent

# ── OpenAI / LLM ──
PDF_AGENT_OPENAI_API_KEY=sk-your-key-here
PDF_AGENT_OPENAI_BASE_URL=              # leave empty for official OpenAI
PDF_AGENT_OPENAI_MODEL=gpt-4o
PDF_AGENT_AGENT_TEMPERATURE=0
PDF_AGENT_AGENT_MAX_ITERATIONS=20

# ── Storage ──
PDF_AGENT_DATA_DIR=data

# ── Limits ──
PDF_AGENT_MAX_UPLOAD_SIZE_MB=200
PDF_AGENT_MAX_PAGE_COUNT=2000
PDF_AGENT_EXTERNAL_CMD_TIMEOUT_SEC=1800

# ── Access Control ──
# if set, require X-API-Key header
PDF_AGENT_API_KEY=

# ── CORS ──
PDF_AGENT_CORS_ORIGINS=*               # comma-separated, e.g. https://app.example.com,http://localhost:3000

# ── LangSmith Tracing ──
PDF_AGENT_LANGSMITH_API_KEY=
PDF_AGENT_LANGSMITH_PROJECT=pdf-agent

# ── Rate Limiting ──
PDF_AGENT_RATE_LIMIT_RPM=20            # per-IP chat requests/minute, 0 = disabled

# ── Cleanup ──
PDF_AGENT_CONVERSATION_TTL_HOURS=72

# ── Observability ──
# Sentry DSN for error tracking
PDF_AGENT_SENTRY_DSN=
PDF_AGENT_METRICS_ENABLED=true         # expose /metrics Prometheus endpoint

# ── i18n ──
PDF_AGENT_DEFAULT_LOCALE=en            # "en" or "zh"

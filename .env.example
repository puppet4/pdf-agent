# ============================================================
# PDF Agent Toolbox — Environment Variables
# Copy to .env and adjust values. All use the PDF_AGENT_ prefix.
# ============================================================

# ── App ──
PDF_AGENT_ENVIRONMENT=development
PDF_AGENT_DEBUG=false

# ── Database (async — FastAPI / SQLAlchemy) ──
PDF_AGENT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pdf_agent

# ── OpenAI / LLM ──
PDF_AGENT_OPENAI_API_KEY=sk-your-key-here
# leave empty for official OpenAI
PDF_AGENT_OPENAI_BASE_URL=
PDF_AGENT_OPENAI_MODEL=gpt-4o
PDF_AGENT_AGENT_TEMPERATURE=0
PDF_AGENT_AGENT_MAX_ITERATIONS=20

# ── Storage ──
PDF_AGENT_DATA_DIR=data

# ── Limits ──
PDF_AGENT_MAX_UPLOAD_SIZE_MB=200
PDF_AGENT_MAX_PAGE_COUNT=2000
PDF_AGENT_EXTERNAL_CMD_TIMEOUT_SEC=1800

# ── Access Control ──
# production requires required auth with a strong API key
PDF_AGENT_AUTH_MODE=optional
PDF_AGENT_API_KEY=
PDF_AGENT_API_KEY_HEADER_NAME=X-API-Key
PDF_AGENT_EXEMPT_AUTH_PATHS=/healthz,/metrics

# ── Legacy API Compatibility ──
# disabled/sunset is the default chat-first release surface.
# Set mode=bridge and phase=deprecation only for migration windows.
PDF_AGENT_LEGACY_API_COMPATIBILITY_MODE=disabled
PDF_AGENT_LEGACY_API_PHASE=sunset

# ── CORS ──
# comma-separated, e.g. https://app.example.com,http://localhost:3000
PDF_AGENT_CORS_ORIGINS=*

# ── LangSmith Tracing ──
PDF_AGENT_LANGSMITH_API_KEY=
PDF_AGENT_LANGSMITH_PROJECT=pdf-agent

# ── Rate Limiting ──
# per-IP chat requests/minute, 0 = disabled
PDF_AGENT_RATE_LIMIT_RPM=200

# ── Cleanup ──
PDF_AGENT_CONVERSATION_TTL_HOURS=72

# ── Observability ──
# Sentry DSN for error tracking
PDF_AGENT_SENTRY_DSN=
# expose /metrics Prometheus endpoint
PDF_AGENT_METRICS_ENABLED=true

# ── i18n ──
# "en" or "zh"
PDF_AGENT_DEFAULT_LOCALE=en
